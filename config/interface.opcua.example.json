{
    "scada_server": {
        "interface": "opcua",
        "specification": {
            "endpoint": "opc.tcp://192.168.1.20:4840",
            "username": "operator",
            "password": "password",
            "period_ms": 100,
            "nodes": {
                "inputs": [
                    { "name": "motor_speed_actual",   "node_id": "ns=1;s=Motor.SpeedActual",   "type": "float32" },
                    { "name": "motor_fault_code",     "node_id": "ns=1;i=1010",                "type": "uint16"  }
                ],
                "outputs": [
                    { "name": "motor_speed_setpoint", "node_id": "ns=1;s=Motor.SpeedSetpoint", "type": "float32" },
                    { "name": "motor_enable",         "node_id": "ns=1;i=1001",                "type": "uint8"   }
                ]
            }
        }
    }
}
